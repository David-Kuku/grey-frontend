                  "pm.test('Payout status is pending', () => pm.expect(res.payout.status).to.eql('pending'));",
                  "pm.test('Transaction status is pending', () => pm.expect(res.transaction.status).to.eql('pending'));",
                  "pm.test('Balance decreased', () => pm.expect(res.new_balance).to.eql(50000000 - 100000));",
                  "",
                  "console.log('Payout ID:', res.payout.id);",
                  "console.log('NGN balance after payout:', res.new_balance);",
                  "console.log('⏳ Payout will transition: pending → processing → success/fail over ~5s');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
