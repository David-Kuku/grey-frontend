    {
      "name": "3. Balances",
      "item": [
        {
          "name": "3a. Get all balances",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has 5 currencies', () => pm.expect(res.balances).to.have.length(5));",
                  "",
                  "const usd = res.balances.find(b => b.currency === 'USD');",
                  "const ngn = res.balances.find(b => b.currency === 'NGN');",
                  "const gbp = res.balances.find(b => b.currency === 'GBP');",
                  "const eur = res.balances.find(b => b.currency === 'EUR');",
                  "",
                  "pm.test('USD = 100000', () => pm.expect(usd.balance_minor).to.eql(100000));",
                  "pm.test('NGN = 50000000', () => pm.expect(ngn.balance_minor).to.eql(50000000));",
                  "pm.test('GBP = 50000', () => pm.expect(gbp.balance_minor).to.eql(50000));",
                  "pm.test('EUR = 0', () => pm.expect(eur.balance_minor).to.eql(0));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/wallet/balances",
              "host": ["{{base_url}}"],
              "path": ["wallet", "balances"]
            }
          }
        }
      ]
    },
    {
      "name": "4. FX Conversion",
      "item": [
        {
          "name": "4a. Get quote: USD → EUR (500.00 USD)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has quote_id', () => pm.expect(res.quote_id).to.be.a('string'));",
                  "pm.test('Source is USD', () => pm.expect(res.source_currency).to.eql('USD'));",
                  "pm.test('Target is EUR', () => pm.expect(res.target_currency).to.eql('EUR'));",
                  "pm.test('Source amount is 50000', () => pm.expect(res.source_amount).to.eql(50000));",
                  "pm.test('Target amount > 0', () => pm.expect(res.target_amount).to.be.above(0));",
                  "pm.test('Market rate != quoted rate (spread applied)', () => {",
                  "  pm.expect(res.market_rate).to.not.eql(res.quoted_rate);",
                  "});",
                  "pm.test('Expires in ~30s', () => pm.expect(res.expires_in_seconds).to.be.within(25, 31));",
                  "",
                  "if (res.quote_id) {",
                  "  pm.collectionVariables.set('quote_id', res.quote_id);",
                  "}",
                  "",
                  "console.log('Market rate:', res.market_rate);",
                  "console.log('Quoted rate:', res.quoted_rate);",
                  "console.log('You send:', res.source_amount, res.source_currency);",
                  "console.log('You get:', res.target_amount, res.target_currency);",
                  "console.log('Fee:', res.fee_amount, res.fee_currency);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_currency\": \"USD\",\n  \"target_currency\": \"EUR\",\n  \"source_amount\": 50000\n}"
            },
            "url": {
              "raw": "{{base_url}}/conversions/quote",
              "host": ["{{base_url}}"],
              "path": ["conversions", "quote"]
            }
          }
        },
        {
          "name": "4b. Execute quote",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Transaction is successful', () => pm.expect(res.transaction.status).to.eql('successful'));",
                  "pm.test('USD balance decreased', () => pm.expect(res.source_balance).to.be.below(100000));",
                  "pm.test('EUR balance increased', () => pm.expect(res.target_balance).to.be.above(0));",
                  "",
                  "console.log('USD remaining:', res.source_balance);",
                  "console.log('EUR received:', res.target_balance);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quote_id\": \"{{quote_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/conversions/execute",
              "host": ["{{base_url}}"],
              "path": ["conversions", "execute"]
            }
          }
        },
        {
