    {
      "name": "6. Transaction History",
      "item": [
        {
          "name": "6a. Get transactions (page 1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has transactions array', () => pm.expect(res.transactions).to.be.an('array'));",
                  "pm.test('Has pagination', () => {",
                  "  pm.expect(res.page).to.eql(1);",
                  "  pm.expect(res.total_count).to.be.above(0);",
                  "});",
                  "pm.test('Transactions are reverse chronological', () => {",
                  "  if (res.transactions.length > 1) {",
                  "    const first = new Date(res.transactions[0].created_at);",
                  "    const second = new Date(res.transactions[1].created_at);",
                  "    pm.expect(first.getTime()).to.be.at.least(second.getTime());",
                  "  }",
                  "});",
                  "",
                  "if (res.transactions && res.transactions.length > 0) {",
                  "  pm.collectionVariables.set('transaction_id', res.transactions[0].id);",
                  "}",
                  "",
                  "console.log('Total transactions:', res.total_count);",
                  "res.transactions.forEach(tx => {",
                  "  console.log(`  ${tx.type} | ${tx.status} | ${tx.amount_formatted || tx.currency}`);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
