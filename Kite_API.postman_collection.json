                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quote_id\": \"{{quote_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/conversions/execute",
              "host": ["{{base_url}}"],
              "path": ["conversions", "execute"]
            }
          }
        },
        {
          "name": "4d. Quote — same currency (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('Validation error', () => {",
                  "  pm.expect(pm.response.json().code).to.eql('VALIDATION_ERROR');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_currency\": \"USD\",\n  \"target_currency\": \"USD\",\n  \"source_amount\": 10000\n}"
            },
            "url": {
              "raw": "{{base_url}}/conversions/quote",
              "host": ["{{base_url}}"],
              "path": ["conversions", "quote"]
            }
          }
        },
        {
          "name": "4e. Quote — insufficient balance (expect 422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 422', () => pm.response.to.have.status(422));",
                  "pm.test('Error is INSUFFICIENT_BALANCE', () => {",
                  "  pm.expect(pm.response.json().code).to.eql('INSUFFICIENT_BALANCE');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_currency\": \"KES\",\n  \"target_currency\": \"USD\",\n  \"source_amount\": 9999999999\n}"
            },
            "url": {
              "raw": "{{base_url}}/conversions/quote",
              "host": ["{{base_url}}"],
              "path": ["conversions", "quote"]
            }
          }
        }
      ]
    },
    {
      "name": "5. Payouts",
      "item": [
        {
          "name": "5a. Create NGN payout (1000 naira)",
          "event": [
            {
              "listen": "test",
