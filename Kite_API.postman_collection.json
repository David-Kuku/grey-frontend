          "name": "7b. Final transaction history",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "const types = res.transactions.map(t => t.type);",
                  "pm.test('Has deposit transactions', () => pm.expect(types).to.include('deposit'));",
                  "pm.test('Has conversion transaction', () => pm.expect(types).to.include('conversion'));",
                  "pm.test('Has payout transaction', () => pm.expect(types).to.include('payout'));",
                  "",
                  "console.log('All transactions:');",
                  "res.transactions.forEach(tx => {",
                  "  console.log(`  ${tx.type} | ${tx.status} | ${tx.description}`);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/transactions?page=1&page_size=50",
              "host": ["{{base_url}}"],
              "path": ["transactions"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "50" }
              ]
            }
          }
        }
      ]
