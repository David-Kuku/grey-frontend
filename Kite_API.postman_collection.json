    {
      "name": "7. Post-Payout Verification",
      "description": "Run these after waiting ~7 seconds for the payout simulation to complete.",
      "item": [
        {
          "name": "7a. Final balances (after payout settles)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "const ngn = res.balances.find(b => b.currency === 'NGN');",
                  "const eur = res.balances.find(b => b.currency === 'EUR');",
                  "",
                  "// NGN: 50000000 - 100000 = 49900000 if payout succeeded",
                  "// NGN: 50000000 if payout failed and reversed",
                  "pm.test('NGN balance is valid (49900000 or 50000000)', () => {",
                  "  pm.expect([49900000, 50000000]).to.include(ngn.balance_minor);",
                  "});",
                  "",
                  "pm.test('EUR balance > 0 (from conversion)', () => {",
                  "  pm.expect(eur.balance_minor).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('No negative balances', () => {",
                  "  res.balances.forEach(b => {",
                  "    pm.expect(b.balance_minor).to.be.at.least(0);",
                  "  });",
                  "});",
                  "",
                  "console.log('Final balances:');",
                  "res.balances.forEach(b => console.log(`  ${b.currency}: ${b.balance}`));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/wallet/balances",
              "host": ["{{base_url}}"],
              "path": ["wallet", "balances"]
            }
          }
        },
